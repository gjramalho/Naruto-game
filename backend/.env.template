# Backend environment template - DO NOT COMMIT SENSITIVE VALUES
# Copy to backend/.env and fill with real values for local development.

# Database (SQL Server)
SA_PASSWORD=ChangeThisToAStrongPassword123!

# JWT configuration
JWT_SECRET=ChangeThisToASuperLongRandomSecretAtLeast32Characters!

# Environment
ASPNETCORE_ENVIRONMENT=Development

# Notes:
