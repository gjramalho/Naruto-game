# ============================================
# ⚠️ IMPORTANTE: Altere estes valores!
# Não use estes valores em produção!
# ============================================

# ============================================
# Configurações do Banco de Dados
# ============================================
# A senha deve ter no mínimo 8 caracteres e atender aos requisitos de complexidade do SQL Server
SA_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# ============================================
# Configurações do JWT
# ============================================
# A chave secreta deve ter pelo menos 32 caracteres para segurança adequada
JWT_SECRET=CHANGE_THIS_TO_A_SECRET_KEY_32CHARS!

# ============================================
# Configurações do Ambiente
# ============================================
ASPNETCORE_ENVIRONMENT=Development
