# ============================================================
# CONFIGURAÇÃO DO PROJETO NARUTO GAME
# ============================================================
# Copie este arquivo para .env e preencha as variáveis

# ============================================================
# BACKEND (SQL Server)
# ============================================================
# Senha do SQL Server (mínimo 8 caracteres, com maiúscula, minúscula e número)
SA_PASSWORD=YourStrong@Password123

# ============================================================
# BACKEND (API .NET)
# ============================================================
# Ambiente de execução (Development/Production)
ASPNETCORE_ENVIRONMENT=Development

# Chave secreta para JWT (mínimo 32 caracteres)
JWT_SECRET=YourSuperSecretKeyForJWTTokenGeneration32Chars

# ============================================================
# FRONTEND (Vite)
# ============================================================
# URL da API backend (usado pelo frontend)
VITE_API_URL=http://localhost:5000
